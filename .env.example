# ================================================
# SIBE - Variables de Entorno
# Copiar este archivo como .env y ajustar los valores segun el ambiente.
# Los valores por defecto ya permiten levantar el sistema localmente.
# ================================================

# --- Base de Datos (PostgreSQL) ---
POSTGRES_DB=sibe_db2
DB_USERNAME=postgres
DB_PASSWORD=admin1234
DB_PORT=5432

# --- Backend (Spring Boot) ---
BACKEND_PORT=8080
DDL_AUTO=update
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost

# --- Frontend (Nginx) ---
FRONTEND_PORT=80

# --- Email (SMTP) ---
